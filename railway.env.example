NODE_ENV=production
# Railway injects PORT automatically
PORT=
APPLICATION_PORT=

# Data source
DATA_SOURCE=mongo
MONGO_URI=<FILL_WITH_MONGODB_URI>

# JWT secrets
JWT_ACCESS_SECRET=<FILL_WITH_STRONG_SECRET>
JWT_REFRESH_SECRET=<FILL_WITH_STRONG_SECRET>

# Browser CORS (comma-separated)
CORS_ORIGINS=https://<FILL_FRONTEND_DOMAIN>

# Refresh cookie
# Use none + true for cross-domain frontend/auth in production
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=
