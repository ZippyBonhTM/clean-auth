NODE_ENV=production
# Railway injects PORT automatically
PORT=
APPLICATION_PORT=

# Data source
DATA_SOURCE=mongo
MONGO_URI=<FILL_WITH_MONGODB_URI>

# JWT secrets
JWT_ACCESS_SECRET=<FILL_WITH_STRONG_SECRET>
JWT_REFRESH_SECRET=<FILL_WITH_STRONG_SECRET>

# Browser CORS (comma-separated)
CORS_ORIGINS=https://<FILL_FRONTEND_DOMAIN>

# Refresh cookie
# Use none + true for cross-domain frontend/auth in production
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=
# Refresh cookie max age in seconds (default: 604800 = 7 days)
REFRESH_COOKIE_MAX_AGE_SECONDS=604800
# Grace window in milliseconds for concurrent refresh retries
REFRESH_ROTATION_GRACE_MS=3000

# Internal service-to-service authorization
AUTH_INTERNAL_SERVICE_TOKEN=<FILL_WITH_SHARED_INTERNAL_SECRET>
