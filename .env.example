NODE_ENV=production
PORT=3002
APPLICATION_PORT=3002
JWT_ACCESS_SECRET="access_secret"
JWT_REFRESH_SECRET="refresh_secret"

# Data source: memory | mongo
DATA_SOURCE=mongo

# Mongo URI aliases (use MONGO_URI as primary)
MONGO_URI=
MONGODB_URI=
MONGODB_URL=
MONGO_URL=
DATABASE_URL=

# Comma-separated origins allowed by CORS (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Mobile/LAN example:
# CORS_ORIGINS=http://192.168.3.5:3000,http://localhost:3000,http://127.0.0.1:3000

# Refresh cookie behavior (recommended in production cross-domain: none + true)
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=
# Refresh cookie max age in seconds (default: 604800 = 7 days)
REFRESH_COOKIE_MAX_AGE_SECONDS=604800
# Local HTTP development alternative:
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=false
